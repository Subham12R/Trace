{
  "name": "trace-desktop",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "author": "Subham12R",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "build:server": "powershell -ExecutionPolicy Bypass -File ..\\server\\build.ps1",
    "build:server:mac": "bash ../server/build.sh",
    "build:electron-main": "npx esbuild electron/main.ts --bundle --platform=node --target=node20 --format=cjs --outfile=electron/main.cjs --external:electron",
    "electron:build": "npm run build:electron-main && npm run build:server && vite build && electron-builder",
    "electron:build:mac": "npm run build:electron-main && npm run build:server:mac && npx vite build && electron-builder --mac",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@hugeicons/core-free-icons": "^4.2.1",
    "@hugeicons/react": "^1.1.7",
    "@tanstack/react-query": "^5.45.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.395.0",
    "motion": "^12.40.0",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-is": "^19.2.7",
    "recharts": "^3.8.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
    "tw-animate-css": "^1.4.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^10.0.3",
    "electron": "31.7.7",
    "electron-builder": "^24.13.3",
    "electron-updater": "^6.8.9",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  },
  "main": "electron/main.cjs"
}
