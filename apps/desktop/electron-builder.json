{
  "appId": "com.trace.app",
  "productName": "Trace",
  "icon": "public/images/icon.png",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "electron/**/*"
  ],
  "extraResources": [
    {
      "from": "../server/dist/server.exe",
      "to": "server/server.exe"
    }
  ],
  "publish": [
    {
      "provider": "github",
      "owner": "Subham12R",
      "repo": "Trace"
    }
  ],
  "mac": {
    "target": "dmg"
  },
  "win": {
    "target": "nsis",
    "artifactName": "Trace-Setup.exe"
  },
  "linux": {
    "target": "AppImage"
  }
}
