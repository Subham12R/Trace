{
  "name": "trace",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first AI CLI usage dashboard",
  "scripts": {
    "dev": "node dev.js",
    "dev:desktop": "cd apps/desktop && npm run dev",
    "dev:electron": "cd apps/desktop && npm run electron:dev",
    "dev:server": "cd apps/server && py -3.12 start.py",
    "build:desktop": "cd apps/desktop && npm run build",
    "lint": "cd apps/desktop && npm run lint"
  },
  "workspaces": [
    "apps/*"
  ],
  "devDependencies": {
    "7zip-bin": "^5.2.0"
  },
  "overrides": {
    "7zip-bin": "^5.2.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
